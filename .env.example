# Quantum-QM/MM POC Environment Configuration
# Copy this file to .env and adjust values as needed

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
PENNYLANE_DEVICE=default.qubit
# Use lightning.gpu for GPU acceleration
# PENNYLANE_DEVICE=lightning.gpu

# Quantum Computation Settings
MAX_QUBITS=20
QPE_ITERATIONS=8
QPE_ALGORITHM=iterative
MAPPING_SCHEME=jordan_wigner

# QM/MM System Settings
MM_MODEL=tip3p
NUM_WATERS=8
SOLVATION_SHELLS=1

# Computation Resources
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4

# Output Configuration
OUTPUT_DIR=data/output
LOG_LEVEL=INFO
SAVE_INTERMEDIATE=true

# Performance Settings
USE_CACHE=true
CACHE_DIR=.cache
BATCH_SIZE=1

# Debug Options
DEBUG_MODE=false
PROFILE_EXECUTION=false